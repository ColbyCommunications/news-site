{
    "name": "colby-college/platform-wp-starter",
    "description": "Starter template for the colby theme",
    "type": "project",
    "require": {
        "johnpbloch/wordpress-core-installer": "^2.0",
        "johnpbloch/wordpress-core": "7.0.0",
        "wpackagist-plugin/header-footer": "3.3.6",
        "wpackagist-plugin/duplicate-post": "4.6",
        "wpackagist-plugin/wordpress-seo": "27.8",
        "wpackagist-plugin/cloudflare": "4.14.3",
        "wpackagist-plugin/public-post-preview": "3.1.0",
        "wpackagist-plugin/wp-saml-auth": "2.3.2",
        "wp-cli/wp-cli-bundle": "^2.4",
        "psy/psysh": "^0.12.22",
        "colbycommunications/advanced-custom-fields-pro": "6.8.2",
        "colbycommunications/gravityforms": "2.10.3",
        "colbycommunications/colby-ticket": "^1.0.0",
        "wpackagist-plugin/wp-search-with-algolia": "2.11.3",
        "vlucas/phpdotenv": "^5.4",
        "colbycommunications/colby-college-theme": "3.10.4",
        "wpackagist-plugin/regenerate-thumbnails": "3.1.6",
        "wpackagist-plugin/disable-comments": "2.7.0",
        "colbycommunications/capabilities-pro": "2.44.0",
        "wpackagist-plugin/wp-nested-pages": "3.2.13",
        "wpackagist-plugin/user-switching": "1.12.0",
        "colbycommunications/presspermit-pro": "4.8.2",
        "wpackagist-plugin/advanced-gutenberg": "3.7.1",
        "wpackagist-plugin/tinymce-advanced": "5.9.2",
        "colbycommunications/wpseo-news": "13.3",
        "colbycommunications/wordpress-seo-premium": "27.8",
        "wpackagist-plugin/gallery-block-lightbox": "1.16.1",
        "wpackagist-plugin/svg-support": "2.5.16",
        "forumone/wp-cfm": "2.0.1",
        "wpackagist-plugin/term-management-tools": "2.0.2",
        "wpackagist-plugin/convert-to-blocks": "1.3.4",
        "wpackagist-plugin/admin-bar-in-fullscreen-mode": "1.0.0",
        "newcity/newcity-wp-wysiwyg": "dev-elementor-compatible",
        "wpackagist-plugin/accordion-blocks": "1.5.0",
        "wpackagist-plugin/acf-autosize": "2.0.15",
        "wpackagist-plugin/acf-extended": "0.9.1",
        "colbycommunications/colby-news-theme": "1.10.4",
        "wpackagist-plugin/reusable-blocks-extended": "0.9.1",
        "wpackagist-plugin/disable-everything": "0.4.1",
        "wpackagist-plugin/block-manager": "3.2.1"
    },
    "authors": [
        {
            "name": "Morty Mule",
            "email": "webmaster@colby.edu"
        }
    ],
    "repositories": [
        {
            "type": "git",
            "url": "https://github.com/ColbyCommunications/colby-news-theme"
        },
        {
            "type": "git",
            "url": "https://github.com/forumone/wp-cfm-dist"
        },
        {
            "type": "composer",
            "url": "https://wpackagist.org/"
        },
        {
            "type": "composer",
            "url": "https://satis.colby.edu"
        },
        {
            "type": "git",
            "url": "https://github.com/ColbyCommunications/colby-college-theme"
        }
    ],
    "extra": {
        "wordpress-install-dir": "web/wp",
        "installer-paths": {
            "web/wp-content/mu-plugins/{$name}": [
                "type:wordpress-muplugin",
                "wpackagist-plugin/wordpress-seo",
                "wpackagist-plugin/wp-search-with-algolia"
            ],
            "web/wp-content/plugins/{$name}": [
                "type:wordpress-plugin"
            ],
            "web/wp-content/themes/{$name}": [
                "type:wordpress-theme"
            ]
        }
    },
    "config": {
        "allow-plugins": true,
        "audit": {
            "block-insecure": false
        }
    }
}